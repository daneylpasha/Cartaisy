# Sample merchant build environment for Cartaisy branded-build verification.
# Every value here is fictional and non-secret. Do not put real merchant
# values, credentials, or production identifiers in this file.
#
# Usage (from the repo root):
#   set -a; source docs/examples/sample-merchant.env; set +a
#   npx expo config --type public
#
# Values exported in the shell take precedence over the local .env file,
# so this can be verified without editing .env.

# --- Native build identity (consumed by app.config.ts) ---
APP_NAME="Acme Outfitters"
APP_SLUG=acme-outfitters
APP_SCHEME=acmeoutfitters
APP_VERSION=1.2.0
IOS_BUNDLE_IDENTIFIER=com.example.acmeoutfitters
IOS_BUILD_NUMBER=12
IOS_APPLE_PAY_MERCHANT_ID=merchant.com.example.acmeoutfitters
ANDROID_PACKAGE=com.example.acmeoutfitters
ANDROID_VERSION_CODE=12

# Real merchant builds must supply merchant-specific Firebase files that
# match the merchant bundle ID/package. The checked-in Cartaisy files are
# referenced here only so config evaluation works in this sample.
IOS_GOOGLE_SERVICES_FILE=./GoogleService-Info.plist
ANDROID_GOOGLE_SERVICES_FILE=./google-services.json

# Real merchant builds must supply merchant-approved icon/splash assets.
# The checked-in Cartaisy assets are referenced here only as placeholders.
APP_ICON_PATH=./assets/images/cartaisy-color-logo.png
APP_NOTIFICATION_ICON_PATH=./assets/images/cartaisy-color-logo.png
APP_NOTIFICATION_COLOR=#1E90FF
ANDROID_ADAPTIVE_ICON_PATH=./assets/images/adaptive-icon.png
ANDROID_ADAPTIVE_ICON_BACKGROUND=#0A2540
SPLASH_BACKGROUND_COLOR=#0A2540

# Per-merchant EAS ownership is a release decision; these placeholders make
# the sample explicit. Real branded builds need their own EAS project.
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
EXPO_OWNER=example-merchant-owner

# --- Public runtime client configuration (bundled into JS) ---
EXPO_PUBLIC_API_BASE_URL=https://api.staging.example.com/api/v1
# Must be a 24-character Mongo ObjectId (validated by api/config/mobileConfig.ts).
EXPO_PUBLIC_STORE_ID=507f1f77bcf86cd799439011
EXPO_PUBLIC_APP_NAME="Acme Outfitters"
EXPO_PUBLIC_APP_SCHEME=acmeoutfitters
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_sample_placeholder
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.com.example.acmeoutfitters
