# EAS build archive ignore rules.
#
# When .easignore exists, EAS CLI uses it INSTEAD of .gitignore to decide
# which files are uploaded to the EAS build worker, so the .gitignore rules
# are mirrored below. Keep the two files in sync
# (guarded by scripts/__tests__/easignore.test.ts).
#
# The native-project exclusions at the bottom make every EAS build
# regenerate ios/ and android/ from app.config.ts (Continuous Native
# Generation), so merchant identity env values cannot be silently
# overridden by the checked-in Cartaisy native projects. Local development
# (npx expo run:ios / npx expo run:android) still uses the checked-in
# projects. See docs/DECISIONS.md and docs/MOBILE_BRANDED_BUILD_CHECKLIST.md.

# OSX
#
.DS_Store

# Xcode
#
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
project.xcworkspace

# Android/IntelliJ
#
build/
.idea
.gradle
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore

# node.js
#
node_modules/
npm-debug.log
yarn-error.log

# BUCK
buck-out/
\.buckd/
*.keystore
!debug.keystore

# fastlane
#
*/fastlane/report.xml
*/fastlane/Preview.html
*/fastlane/screenshots

# Bundle artifacts
*.jsbundle

# CocoaPods
/ios/Pods/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# Testing
/coverage

# Yarn (this repo uses npm; see docs/TESTING.md)
yarn.lock
yarn-error.log

# Tamagui
.tamagui/

# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Generated by expo-cli
expo-env.d.ts

# Checked-in native projects: excluded so every EAS build regenerates them
# from app.config.ts (Continuous Native Generation). Do not remove.
/ios
/android
