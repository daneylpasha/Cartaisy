# ===========================================
# CARTAISY MOBILE APP - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your store-specific values
# All EXPO_PUBLIC_ prefixed variables are accessible in the app

# ===========================================
# BACKEND API CONFIGURATION
# ===========================================
# Your backend API base URL (without trailing slash)
EXPO_PUBLIC_API_BASE_URL=https://your-backend.com/api/v1

# ===========================================
# MULTI-TENANCY / STORE IDENTIFICATION
# ===========================================
# Unique Store ID provided by Cartaisy admin (MongoDB ObjectID)
EXPO_PUBLIC_STORE_ID=your_store_id_here

# ===========================================
# SHOPIFY CONFIGURATION
# ===========================================
# Your Shopify store URL (without trailing slash)
EXPO_PUBLIC_SHOPIFY_STORE_URL=https://your-store.myshopify.com

# Shopify Admin API Access Token (starts with shpat_)
EXPO_PUBLIC_SHOPIFY_ACCESS_TOKEN=shpat_your_access_token_here

# Shopify API Version (optional - defaults to 2025-07)
EXPO_PUBLIC_SHOPIFY_API_VERSION=2025-07

# ===========================================
# STRIPE PAYMENT CONFIGURATION
# ===========================================
# Stripe Publishable Key (starts with pk_test_ or pk_live_)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Merchant Identifier for Apple Pay (format: merchant.com.yourcompany)
EXPO_PUBLIC_STRIPE_MERCHANT_ID=merchant.com.yourcompany

# ===========================================
# APP IDENTITY CONFIGURATION
# ===========================================
# App URL Scheme for deep linking (lowercase, no spaces)
EXPO_PUBLIC_APP_SCHEME=yourappname

# App Display Name (shown on device home screen)
EXPO_PUBLIC_APP_NAME=Your App Name

# iOS Bundle Identifier (format: com.company.appname)
EXPO_PUBLIC_IOS_BUNDLE_ID=com.yourcompany.app

# Android Package Name (format: com.company.appname)
EXPO_PUBLIC_ANDROID_PACKAGE=com.yourcompany.app
