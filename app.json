{
  "expo": {
    "name": "cartaisy",
    "slug": "cartaisy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/cartaisy-color-logo.png",
    "scheme": "cartaisy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#8B5CF6",
      "androidMode": "default",
      "androidCollapsedTitle": "{{unread_count}} new notifications"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rendernext.cartaisy",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      },
      "entitlements": {
        "com.apple.developer.in-app-payments": ["merchant.com.cartaisy"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rendernext.cartaisy",
      "googleServicesFile": "./google-services.json",
      "permissions": ["NOTIFICATIONS", "VIBRATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/cartaisy-color-logo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "android": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-router",
      "expo-mail-composer",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/cartaisy-color-logo.png",
          "color": "#8B5CF6",
          "sounds": []
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.cartaisy",
          "enableGooglePay": true
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "eabf3411-284b-4bd8-88eb-8d89a8a4ee14"
      },
      "router": {}
    },
    "owner": "rendernext"
  }
}
